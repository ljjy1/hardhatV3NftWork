{
  "name": "hardhatv3nftwork",
  "version": "1.0.0",
  "description": "hardhat框架实现实现一个 NFT 拍卖市场作业",
  "main": "index.js",
  "scripts": {
    "test:local": "npx hardhat test test/local/*.ts --network hardhatMainnet",
    "test:sepolia": "npx hardhat test test/sepolia/*.ts --network sepolia",
    "test:local:coverage": "npx hardhat test test/local/*.ts --network hardhatMainnet --coverage",
    "test:sepolia:coverage": "npx hardhat test test/sepolia/*.ts --network sepolia --coverage",
    "test:uups": "npx hardhat test test/uups/*.ts --network hardhatMainnet",
    "deploy:local": "npx hardhat run scripts/deploy.ts --network hardhatMainnet",
    "deploy:sepolia": "npx hardhat run scripts/deploy.ts --network sepolia",
    "upgrade:local": "npx hardhat run scripts/upgrade.ts --network hardhatMainnet",
    "upgrade:sepolia": "npx hardhat run scripts/upgrade.ts --network sepolia"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ljjy1/hardhatV3NftWork.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/ljjy1/hardhatV3NftWork/issues"
  },
  "homepage": "https://github.com/ljjy1/hardhatV3NftWork#readme",
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^4.0.6",
    "@nomicfoundation/hardhat-ignition": "^3.0.9",
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.3",
    "@openzeppelin/hardhat-upgrades": "^4.0.0-alpha.0",
    "@types/chai": "^5.2.3",
    "@types/chai-as-promised": "^8.0.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.15",
    "chai": "^6.2.2",
    "ethers": "^6.16.0",
    "forge-std": "github:foundry-rs/forge-std#v1.9.4",
    "hardhat": "^3.2.0",
    "mocha": "^11.7.5",
    "typescript": "~5.8.0"
  },
  "type": "module",
  "dependencies": {
    "@chainlink/contracts": "^1.5.0",
    "@openzeppelin/contracts": "^5.6.1",
    "@openzeppelin/contracts-upgradeable": "^5.6.1",
    "dotenv": "^17.3.1",
    "hardhat-deploy": "^2.0.1"
  }
}
